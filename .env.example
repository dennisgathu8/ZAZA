# Required — HMAC secret key for cryptographic token signing.
# Use a long random string (minimum 32 characters). Never commit the real value.
DAGGA_BAY_SECRET=your-secret-key-here

# Optional — Set to "production" to enable Secure flag on session cookies.
# Any value other than "production" disables the Secure flag (for local dev).
DAGGA_BAY_MODE=production

# Optional — Port the HTTP server binds to. Defaults to 3000 if unset.
PORT=3000

# Optional — Host/interface the HTTP server binds to. Defaults to 0.0.0.0 if unset.
HOST=0.0.0.0
